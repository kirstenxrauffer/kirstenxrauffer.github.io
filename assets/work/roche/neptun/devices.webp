  margin-bottom: 0 !important;
  display: inherit;
}

.newsletter-page-header-section .et_pb_column, .et_pb_row, .et_pb_row_inner {
  background-size: cover;
  background-position: 50%;
  background-repeat: no-repeat;
}
.et_pb_column {
