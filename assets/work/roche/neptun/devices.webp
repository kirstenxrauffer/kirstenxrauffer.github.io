<style type="text/css">
/* --- Team - Info Cards - Reverse flow on every 2nd card, Increased Padding on description ---- */
@media (max-width: 980px) and (min-width: 480px) { 
  .team-info_cards .et_pb_promo_description {
   margin-top: 50%!important;
}
  .team-info_cards .et_pb_row:nth-child(odd) .et_pb_column:nth-child(1) {
    order: 1;
  }
  
  .team-info_cards .et_pb_row:nth-child(odd) .et_pb_column:nth-child(2) {
    order: 2;
  }
  
  .team-info_cards .et_pb_row:nth-child(odd) .et_pb_column:nth-child(3) {
    order: 4;
  }
  
  .team-info_cards .et_pb_row:nth-child(odd) .et_pb_column:nth-child(4) {
    order: 3;
  }
  
   .team-info_cards .et_pb_row:nth-child(even) .et_pb_column:nth-child(1) {
    order: 2;
  }
  
  .team-info_cards .et_pb_row:nth-child(even) .et_pb_column:nth-child(2) {
    order: 1;
  }
  
  .team-info_cards .et_pb_row:nth-child(even) .et_pb_column:nth-child(3) {
    order: 3;
  }
  
  .team-info_cards .et_pb_row:nth-child(even) .et_pb_column:nth-child(4) {
    order: 4;
  }
  
}


@media (max-width: 479px) {
.team-info_cards .et_pb_row:nth-child(even) {
  flex-direction: column-reverse!important;
}

.team-info_cards .et_pb_promo_description {
    padding-bottom: 20%!important;
}

.team-info_cards .et_pb_promo_description {
   margin-top: -15%!important;
   margin-left: -3%!important;
}
}
