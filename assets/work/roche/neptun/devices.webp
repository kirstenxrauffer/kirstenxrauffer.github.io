<style type="text/css">
@media (min-width: 767px) {
.et-blog-css-grid > div {
  display: grid;
  grid-template-columns: repeat(3, minmax(200px, 1fr));
  gap: 30px;
}

.et-blog-css-grid .et_pb_post {
  align-self: start;
  padding-bottom: 10px;
}
	
.et-blog-css-grid .et_pb_post .post-content .post-content-inner p  {
  text-align: start !important;
}
	
.et-blog-css-grid .entry-featured-image-url {
  margin-bottom: 16px;
}
	
/* Don't treat pagination as a grid item */
.et-blog-css-grid > div > div {
  width: 100%;
  position: absolute;
  bottom: 0;
  transform: translate(0%, 150%);
}

/* Unify Image Sizes, may be necessary later */
/* .et-blog-css-grid .entry-featured-image-url {
  padding-top: 56.25%;
}

.et-blog-css-grid .entry-featured-image-url img {
  position: absolute;
  height: 100%;
  width: 100%;
  top: 0;
  object-fit: cover;
} */
	
/*add a neceassry position to the blog posts*/
.et-blog-css-grid .et_pb_post, .et_pb_posts .et_pb_post {
position: relative;
}
/*make the title link spread over the entire post*/
.et-blog-css-grid .et_pb_post .entry-title a:after, .et_pb_posts .et_pb_post .entry-title a:after {
position: absolute;
display: block;
content: "";
width: 100%;
height: 100%;
