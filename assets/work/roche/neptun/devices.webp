  }
}

.newsletter-page-header-section .et_pb_image_0.et_pb_module {
  margin-left: 0px !important;
  margin-right: auto !important;
}
.newsletter-page-header-section .et_pb_image_0 {
  margin-top: 0px !important;
  width: 40px;
  text-align: left;
