<style type="text/css">
#main-content > div {
	min-width: 100%;
}

#content-area {
	min-width: 100%;
	display: flex;
	justify-content: stretch;
}

div#block-2 {
	width: 80%;
}

div#block-9 {
	width: 80%;
}

#left-area {
	flex-basis: 75%;
	max-width: 50%;
	margin-left: auto;
}

#sidebar {
	flex-basis: 20%;
	padding-right: 5%;
	min-height: 100%;
	position: relative;
	overflow: hidden
}

#block-13 {
	position: fixed;
	right: 0;
	min-width: 20%;
	max-width: 20%;
	padding-right: 2%;
	padding-left: 2%;
}

#block-13 p {
	text-align: center;
	margin: auto;
	width: 80%;
}

#block-13 a {
	text-align: center;
}

#block-13 img {
	margin: auto;
}

#block-13 figure {
	display: flex;
	justify-content: center;
	margin: auto;
	width: 80%;
}

#block-13 figure a {
	width: 100%;
}

.sidebar-download-link {
	color: rgb(27, 184, 234) !important;
	text-decoration: underline !important;
	padding: 0 5px !important;
	background-size: 200% 100% !important;
	background-image: linear-gradient(to left, rgb(27, 184, 234) 50%, transparent 50%) !important;
	transition: 0.5s !important;
}

#sidebar-contact-en {
	display: none;
}

#sidebar-contact {
	display: block !important;
	width: 100%;
}

#sidebar-contact img {
	display: block;
	width: 40%;
	margin: auto;
	margin-bottom: 10px;
}

#sidebar-contact hr {
	margin-top: 10px;
	margin-bottom: 15px;
}

#sidebar-contact p {
	text-align: start !important;
	margin-left: 0;
	margin-right: 0;
	width: 100%;
}

#sidebar-contact a {
	text-align: start !important;
}

#sidebar-contact span {
	color: rgb(87, 181, 229);
	font-weight: bold;
	letter-spacing: 0;
}

#speak-with-malte {
	margin-bottom: 5px;
}

#sidebar-contact-en img {
	display: block;
	width: 40%;
	margin: auto;
	margin-bottom: 10px;
}

#sidebar-contact-en hr {
	margin-top: 10px;
	margin-bottom: 15px;
}

#sidebar-contact-en p {
	text-align: start !important;
	margin-left: 0;
	margin-right: 0;
	width: 100%;
}

#sidebar-contact-en a {
	text-align: start !important;
}

#sidebar-contact-en span {
	color: rgb(87, 181, 229);
	font-weight: bold;
	letter-spacing: 0;
}

#speak-with-malte {
	margin-bottom: 5px;
}

.sidebar-contact-method {
	display: flex !important;
	justify-content: center;
	align-items: start;
	margin-top: 5px;
	margin-bottom: 5px;
}

.sidebar-contact-method p {
	display: inline !important;
	flex-grow: 2;
}

.sidebar-contact-method img {
	display: inline !important;
	width: 20px !important;
	flex-shrink: 2;
}

.sidebar-contact-method a {
	display: inline !important;
	width: 20px !important;
	text-decoration: underline;
	flex-grow: 2;
}

.sidebar-title {
	font-weight: bold;
}

#sidebar-mail {
	font-size: 16px;
	color: black !important;
	margin-left: 10px !important;
}

#sidebar-phone {
	font-size: 16px;
	color: black !important;
	margin-left: 10px !important;
}

#sidebar-contact hr {
	display: none;
}

#sidebar-contact-en hr {
	display: none;
}

@media all and (max-width: 980px) {
	#sidebar {
		display: none;
	}
	#content-area {
		display: normal;
	}
	#left-area {
		max-width: 90%;
		margin: auto !important;
		flex-basis: 90%;
	}
}
</style>
