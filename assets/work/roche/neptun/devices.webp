<style type="text/css">
#mc_embed_signup {
	background-color: #FFFFFF;
	border: 1px solid #CCCCCC;
	padding: 20px;
	font: 24px "Open Sans","Arial",sans-serif;
}

.form-headline {
	text-align: center;	
}

.form-headline h3 {
	margin-top: 0;
	margin-bottom: 10px;
}

.form-text p {
	font-size: 16px;
}

.form-email-group input {
	display: block;
    border: 1px solid #CCC;
    color: rgba(0,0,0,0.75);
    font-size: 16px;
    font-weight: normal;
    font-family: inherit;
    padding: 8px;
    height: 37px;
    width: calc(100% - 18px);
    margin-bottom: 15px;
}

#mc-embedded-subscribe {
	color: #FFFFFF;
    background-color: #41b6e6;
	border: none;
	padding: 0;
    border: 0;
    -moz-border-radius: 0;
    -webkit-border-radius: 0;
    border-radius: 0;
    font-weight: normal;
    display: inline-block;
    width: 100%;
    height: 36px;
    font-size: 16px;
    text-align: center;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
}

.form-footnote {
	color: #999;
    font-size: 12px;
	margin-bottom: 0;
}

.form-footnote p{
	margin-bottom: 0;
}
</style>
